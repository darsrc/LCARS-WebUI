exports[`Phase 13 control snapshots > toggle off 1`] = `
<article
  class="lcars-widget lcars-accent-orange"
  style="--lcars-accent: var(--lcars-color-orange);"
>
  <div
    class="lcars-control-toggle"
  >
    <input
      aria-label="Shields"
      class="lcars-control-native-checkbox"
      type="checkbox"
    />
    <div
      aria-hidden="true"
      class="lcars-control-toggle-surface"
    >
      <span
        class="lcars-toggle-segment"
      >
        ON
      </span>
      <span
        class="lcars-toggle-segment active"
      >
        OFF
      </span>
    </div>
  </div>
</article>
`;

exports[`Phase 13 control snapshots > toggle on 1`] = `
<article
  class="lcars-widget lcars-accent-orange"
  style="--lcars-accent: var(--lcars-color-orange);"
>
  <div
    class="lcars-control-toggle"
  >
    <input
      aria-label="Shields"
      checked=""
      class="lcars-control-native-checkbox"
      type="checkbox"
    />
    <div
      aria-hidden="true"
      class="lcars-control-toggle-surface"
    >
      <span
        class="lcars-toggle-segment active"
      >
        ON
      </span>
      <span
        class="lcars-toggle-segment"
      >
        OFF
      </span>
    </div>
  </div>
</article>
