exports[`Phase 13 control snapshots > select with second option selected 1`] = `
<article
  class="lcars-widget lcars-accent-blue"
  style="--lcars-accent: var(--lcars-color-blue);"
>
  <div
    class="lcars-control-select"
  >
    <select
      aria-label="Mode"
      class="lcars-control-native-select"
    >
      <option
        value="science"
      >
        Science
      </option>
      <option
        value="ops"
      >
        Operations
      </option>
      <option
        value="tactical"
      >
        Tactical
      </option>
    </select>
    <div
      aria-hidden="true"
      class="lcars-control-select-stack"
    >
      <button
        class="lcars-select-bar"
        type="button"
      >
        Science
      </button>
      <button
        class="lcars-select-bar active"
        type="button"
      >
        Operations
      </button>
      <button
        class="lcars-select-bar"
        type="button"
      >
        Tactical
      </button>
    </div>
  </div>
</article>
`;

