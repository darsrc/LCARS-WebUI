          "description": "Action id emitted when clicked.",
          "title": "Action Id",
          "type": "string"
        },
        "color": {
          "anyOf": [
            {
              "enum": [
                "orange",
                "red",
                "blue",
                "purple",
                "white",
                "yellow"
              ],
              "type": "string"
            },
