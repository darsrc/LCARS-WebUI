{
  "$defs": {
    "Alert": {
      "description": "High-visibility alert banner.",
      "properties": {
        "blink": {
          "default": false,
          "description": "If true, alert pulses opacity.",
          "title": "Blink",
          "type": "boolean"
        },
        "color": {
          "anyOf": [
            {
              "enum": [
                "orange",
                "red",
                "blue",
                "purple",
                "white",
                "yellow"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional LCARS palette color.",
          "title": "Color"
        },
        "disabled": {
          "default": false,
          "description": "If true, interaction is disabled.",
          "title": "Disabled",
          "type": "boolean"
        },
        "id": {
          "description": "Unique widget identifier used for event targeting.",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional display or accessibility label.",
          "title": "Label"
        },
        "message": {
          "description": "Alert message.",
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "description": "Alert severity level.",
          "enum": [
            "red",
            "yellow"
          ],
          "title": "Severity",
          "type": "string"
        },
        "type": {
          "const": "alert",
          "default": "alert",
          "title": "Type",
          "type": "string"
        },
        "visible": {
          "default": true,
          "description": "If false, widget is removed from layout flow.",
          "title": "Visible",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "severity",
        "message"
      ],
      "title": "Alert",
      "type": "object"
    },
    "Button": {
