    "Column": {
      "description": "A page column.",
      "properties": {
        "id": {
          "description": "Unique column identifier.",
          "title": "Id",
          "type": "string"
        },
        "widgets": {
          "description": "Widgets in this column.",
          "items": {
            "discriminator": {
              "mapping": {
                "alert": "#/$defs/Alert",
                "button": "#/$defs/Button",
                "form": "#/$defs/Form",
                "line_chart": "#/$defs/LineChart",
                "log_viewer": "#/$defs/LogViewer",
                "mic_button": "#/$defs/MicButton",
                "select": "#/$defs/Select",
                "sparkline": "#/$defs/Sparkline",
                "status_tile": "#/$defs/StatusTile",
                "table": "#/$defs/Table",
                "text": "#/$defs/Text",
                "text_input": "#/$defs/TextInput",
                "toggle": "#/$defs/Toggle",
                "video_hls": "#/$defs/VideoHls"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/Text"
              },
              {
                "$ref": "#/$defs/StatusTile"
              },
              {
                "$ref": "#/$defs/Alert"
              },
              {
                "$ref": "#/$defs/Button"
              },
              {
                "$ref": "#/$defs/Toggle"
              },
              {
                "$ref": "#/$defs/Select"
              },
              {
                "$ref": "#/$defs/TextInput"
              },
              {
                "$ref": "#/$defs/Form"
              },
              {
                "$ref": "#/$defs/Table"
              },
              {
                "$ref": "#/$defs/LineChart"
              },
              {
                "$ref": "#/$defs/Sparkline"
              },
              {
                "$ref": "#/$defs/LogViewer"
              },
              {
                "$ref": "#/$defs/VideoHls"
              },
              {
                "$ref": "#/$defs/MicButton"
              }
            ]
          },
          "title": "Widgets",
          "type": "array"
        },
        "width": {
          "default": "1fr",
          "description": "Layout width hint (e.g. 1fr, 300px).",
          "title": "Width",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "Column",
      "type": "object"
    },
